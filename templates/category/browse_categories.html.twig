{% extends 'base.html.twig' %}

{% block title %}Catégories - E-Shop EHEI{% endblock %}

{% block body %}
<h1 class="section-title" id="categories-page-title">Toutes les Catégories</h1>

{% if categories is empty %}
    <div class="card" style="text-align: center; padding: 3rem;" id="no-categories-card">
        <p style="color: var(--text-secondary);">Aucune catégorie disponible. Veuillez charger la base de données.</p>
    </div>
{% else %}
    <div class="grid" id="categories-grid">
        {% for category in categories %}
            <div class="card" style="align-items: center; text-align: center; padding: 2.5rem;" id="category-card-{{ category.id }}">
                <div class="card-img-placeholder" style="width: 80px; height: 80px; border-radius: 50%; font-size: 2.5rem;" id="category-avatar-{{ category.id }}">
                    {% if category.name|lower == 'ordinateurs' or category.name|lower == 'laptops' %}💻
                    {% elseif category.name|lower == 'téléphones' or category.name|lower == 'smartphones' or category.name|lower == 'phones' %}📱
                    {% elseif category.name|lower == 'accessoires' %}🎧
                    {% else %}📦
                    {% endif %}
                </div>
                
                <h2 class="card-title" style="margin-top: 1rem;" id="category-name-{{ category.id }}">{{ category.name }}</h2>
                <p class="card-desc" style="margin-bottom: 1.5rem;" id="category-count-{{ category.id }}">{{ category.products|length }} Produits</p>
                
                <a href="{{ path('products_by_category', {'id': category.id}) }}" class="btn-secondary" id="category-link-{{ category.id }}">
                    Parcourir →
                </a>
            </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
